<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ICT AOR Assistant</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/css/style.css" >
</head>
<body>
    <main class="container">
        <%- include('../partials/navbar'); %>

        <div class="welcome-container">
            <h1>ICT AOR Assistant</h1>
            <h2>Submit your query below to get started.</h2>
        </div>

        <form action="/generate" method="post" enctype="multipart/form-data">
            <label for="userInput">Your Query</label>
            <textarea id="userInput" name="userInput" placeholder="Enter your query here..." rows="5"></textarea>

            <label for="attachment">Attach a file (optional)</label>
            <input type="file" id="attachment" name="attachment">

            <button type="submit">Submit</button>
        </form>

        <% if (error) { %>
            <article class="error-container">
                <p><%= error %></p>
            </article>
        <% } %>

        <% if (result) { %>
            <article class="result-container">
                <h3>Result</h3>
                <p><%= result %></p>
            </article>
        <% } %>
    </main>
</body>
</html>